#!/usr/bin/env sh

export GOOGLE_APPLICATION_CREDENTIALS="../../private_keys/firebase_service_accounts/cloud_storage_service_account.json"

# Handle --clean flag
if [ "$1" = "--clean" ]; then
  echo "🧹 Cleaning upload cache..."
  rm -f bin/firebase_admin/upload_cache.json
fi

cd bin/firebase_admin && node upload_files_to_firestore_storages.js
