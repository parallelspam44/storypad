#!/bin/bash -e

# Generate story backgrounds
echo "Generating story backgrounds..."
dart bin/backgrounds_generation/generate.dart

echo ""
echo "Running build_runner..."

CMD="dart run build_runner build"

# Check if --delete flag is provided
if echo "$@" | grep -q -- "--delete"; then
  CMD="$CMD --delete-conflicting-outputs"
fi

echo "Executing: $CMD"
exec $CMD
