#!/usr/bin/env sh

# Use this [bin/dev] to run Flutter project in specific flavor.
#
# Commands:
# bin/dev --community
# bin/dev --storypad
# bin/dev --spooky
# 
# bin/dev --community-ios
# bin/dev --storypad-ios
# bin/dev --spooky-ios
# 
# bin/dev --community-macos
# bin/dev --storypad-macos
# bin/dev --spooky-macos

INPUT=$1
FLAVOR=$(echo "$INPUT" | sed -E 's/--([a-z]+)(-ios|-macos)?/\1/')
BASE_ARG="--target=lib/main_${FLAVOR}.dart --flavor $FLAVOR --dart-define-from-file=private_keys/dart_defines/${FLAVOR}.json"

# Export keystore paths: android/app/build.gradle.kts:80
export DEBUG_KEYSTORE_PATH="../../private_keys/android_keystores/${FLAVOR}_debug.keystore"
export DEBUG_KEYSTORE_PASSWORD="android"
export DEBUG_KEY_PASSWORD="android"
export DEBUG_KEY_ALIAS="androiddebugkey"

case "$INPUT" in
--storypad)
  CMD="flutter run $BASE_ARG"
  ;;
--spooky)
  CMD="flutter run $BASE_ARG"
  ;;
--community | "")
  CMD="flutter run $BASE_ARG"
  ;;
--storypad-ios)
  CMD="flutter run $BASE_ARG --dart-define=CUPERTINO=yes"
  ;;
--storypad-macos)
  CMD="flutter run $BASE_ARG --dart-define=CUPERTINO=yes -d macos"
  ;;
--spooky-ios)
  CMD="flutter run $BASE_ARG --dart-define=CUPERTINO=yes"
  ;;
--community-ios | "")
  CMD="flutter run $BASE_ARG --dart-define=CUPERTINO=yes"
  ;;
--community-macos | "")
  CMD="flutter run $BASE_ARG --dart-define=CUPERTINO=yes -d macos"
  ;;
*)
  echo "Invalid option: $FLAVOR"
  echo "Usage: bin/dev [--storypad | --spooky | --community]"
  exit 1
  ;;
esac

# Remove 1st args
shift

echo "Executing: $CMD $1"
eval $CMD $1
